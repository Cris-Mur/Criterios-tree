---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Button from '@components/ui/Button.astro';
import { Image } from 'astro:assets';
import logoImage from '@assets/branding/logo.png';

interface Props {
	title?: string;
	subtitle?: string;
}

const { 
	title = "El Sabor del Conocimiento Ancestral.", 
	subtitle = "Repostería artesanal para el bienestar. Descubre una experiencia de sabor galáctico diseñada para tu equilibrio." 
} = Astro.props;
---

<SectionContainer variant="nebula" class="hero">
	<div class="hero__content">
		<div class="hero__branding">
			<Image 
				src={logoImage} 
				alt="Criterios Logo" 
				width={180} 
				height={180} 
				class="hero__logo"
				loading="eager"
			/>
		</div>
		
		<h1 class="hero__title text-glow">
			{title}
		</h1>
		
		<p class="hero__subtitle">
			{subtitle}
		</p>
		
		<div class="hero__actions">
			<Button href="/catalogo" variant="solid" class="hero__btn">
				Explorar Catálogo
			</Button>
			<Button variant="outline" href="#historia">
				Nuestra Historia
			</Button>
		</div>
	</div>

	<div class="hero__background-overlay"></div>
</SectionContainer>

<style>
	.hero {
		min-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		position: relative;
	}

	.hero__content {
		position: relative;
		z-index: 10;
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-md);
	}

	.hero__branding {
		margin-bottom: var(--space-sm);
		animation: float 6s ease-in-out infinite;
	}

	.hero__logo {
		filter: drop-shadow(0 0 15px var(--color-gold-glow));
	}

	.hero__title {
		font-size: clamp(2rem, 8vw, 4rem);
		line-height: 1.1;
		margin: 0;
	}

	.hero__subtitle {
		font-size: clamp(1rem, 4vw, 1.25rem);
		color: var(--color-stardust);
		opacity: 0.9;
		max-width: 600px;
		line-height: 1.6;
	}

	.hero__actions {
		display: flex;
		gap: var(--space-md);
		flex-wrap: wrap;
		justify-content: center;
		margin-top: var(--space-sm);
	}

	.hero__background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: radial-gradient(circle at center, transparent 0%, var(--color-void) 100%);
		pointer-events: none;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-15px); }
	}

	/* Optimizaciones para Mobile */
	@media (max-width: 768px) {
		.hero {
			min-height: 90vh;
			padding-top: var(--space-xl);
		}
		.hero__actions {
			flex-direction: column;
			width: 100%;
			max-width: 280px;
		}
	}
</style>
