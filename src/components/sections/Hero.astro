---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Button from '@components/ui/Button.astro';
import { Image, getImage } from 'astro:assets';
import logoImage from '@assets/branding/logo.png';
import bgImage from '@assets/branding/hero-bg.jpg';
import '@styles/components/hero.css';

interface Props {
	title?: string;
	subtitle?: string;
}

const { 
	title = "El Sabor del Conocimiento Ancestral.", 
	subtitle = "Repostería artesanal para el bienestar. Descubre una experiencia de sabor galáctico diseñada para tu equilibrio." 
} = Astro.props;

// Optimizamos la imagen de fondo para usarla en CSS
const optimizedBg = await getImage({ src: bgImage, format: 'webp' });
---

<SectionContainer 
	variant="nebula" 
	class="hero" 
	style={`--hero-bg: url(${optimizedBg.src})`}
>
	<div class="hero__content">
		<div class="hero__branding">
			<Image 
				src={logoImage} 
				alt="Criterios Logo" 
				width={180} 
				height={180} 
				class="hero__logo"
				loading="eager"
			/>
		</div>
		
		<h1 class="hero__title text-glow">
			{title}
		</h1>
		
		<p class="hero__subtitle">
			{subtitle}
		</p>
		
		<div class="hero__actions">
			<Button href="/catalogo" variant="solid" class="hero__btn">
				Explorar Catálogo
			</Button>
			<Button variant="outline" href="#historia">
				Nuestra Historia
			</Button>
		</div>
	</div>

	<div class="hero__background-overlay"></div>
</SectionContainer>
