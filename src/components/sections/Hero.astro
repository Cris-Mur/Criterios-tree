---
import HeroLogo from '@components/ui/HeroLogo.astro';
import HeroActions from '@components/ui/HeroActions.astro';
import { getImage } from 'astro:assets';
import bgImage from '@assets/branding/hero-bg.jpg';
import '@styles/components/hero.css';

interface Props {
	title?: string;
	subtitle?: string;
}

const { 
	title = "El Sabor del Conocimiento Ancestral.", 
	subtitle = "Repostería artesanal para el bienestar. Descubre una experiencia de sabor galáctico diseñada para tu equilibrio." 
} = Astro.props;

const optimizedBg = await getImage({ src: bgImage, format: 'webp' });
---

<section 
	class="hero" 
	style={`--hero-bg: url(${optimizedBg.src})`}
>
	<div class="hero__sticky">
		<div class="hero__content">
			<HeroLogo class="js-hero-logo" />
			
			<h1 class="hero__title text-glow js-hero-title">
				{title}
			</h1>
			
			<p class="hero__subtitle js-hero-subtitle">
				{subtitle}
			</p>
			
			<div class="hero__actions-wrapper js-hero-actions">
				<HeroActions />
			</div>
		</div>
		<div class="hero__background-overlay"></div>
	</div>
</section>

<script>
	import { animations } from '@utils/animations';

	const hero = document.querySelector('.hero') as HTMLElement;
	const logo = document.querySelector('.js-hero-logo') as HTMLElement;
	const textElements = [
		'.js-hero-title',
		'.js-hero-subtitle',
		'.js-hero-actions'
	];

	if (hero && logo) {
		const tl = animations.createScrollTimeline(hero);

		// 1. Parallax sutil en el fondo
		tl.to(hero, {
			backgroundPositionY: "20%",
			ease: "none"
		}, 0);

		// 2. Logo sube, escala y aumenta su brillo
		tl.fromTo(logo, 
			{ 
				y: "35vh", 
				scale: 0.7, 
				opacity: 0.4,
				filter: "drop-shadow(0 0 5px var(--color-gold-glow))" 
			}, 
			{ 
				y: "0vh", 
				scale: 1.4, 
				opacity: 1, 
				filter: "drop-shadow(0 0 25px var(--color-gold-glow))",
				duration: 1 
			}, 0
		);

		// 3. Revelación coordinada de textos
		tl.to(textElements, {
			opacity: 1,
			y: 0,
			stagger: 0.15,
			duration: 0.6
		}, "-=0.4");
	}
</script>
