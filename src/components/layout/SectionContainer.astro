---
import '@styles/components/section-container.css';

interface Props {
	id?: string;
	class?: string;
	variant?: 'default' | 'stardust' | 'nebula';
	fullWidth?: boolean;
}

const { 
	id, 
	class: className, 
	variant = 'default',
	fullWidth = false
} = Astro.props;
---

<section id={id} class:list={[
	'section',
	`section--${variant}`,
	className
]}>
	<div class:list={['section__content', { 'section__content--full': fullWidth }]}>
		<slot />
	</div>
</section>
