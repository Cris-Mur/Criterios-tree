---
interface Props {
	id?: string;
	class?: string;
	variant?: 'default' | 'stardust' | 'nebula';
	fullWidth?: boolean;
}

const { 
	id, 
	class: className, 
	variant = 'default',
	fullWidth = false
} = Astro.props;
---

<section id={id} class:list={[
	'section',
	`section--${variant}`,
	className
]}>
	<div class:list={['section__content', { 'section__content--full': fullWidth }]}>
		<slot />
	</div>
</section>

<style>
	.section {
		position: relative;
		padding: var(--space-lg) 0;
		overflow: hidden;
		width: 100%;
	}

	.section__content {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 var(--space-sm);
	}

	.section__content--full {
		max-width: none;
		padding: 0;
	}

	/* Variante Stardust: Efecto de fondo galáctico sutil */
	.section--stardust {
		background-image: 
			radial-gradient(circle at 20% 30%, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
			radial-gradient(circle at 80% 70%, rgba(212, 175, 55, 0.05) 0%, transparent 50%);
	}

	.section--stardust::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image: url('/assets/stardust-pattern.png'); /* Placeholder para futura textura */
		opacity: 0.1;
		pointer-events: none;
	}

	/* Variante Nebula: Gradiente de profundidad */
	.section--nebula {
		background: linear-gradient(180deg, var(--color-void) 0%, var(--color-deep-space) 100%);
		border-top: 1px solid var(--color-gold-glow);
	}

	@media (min-width: 768px) {
		.section {
			padding: var(--space-xl) 0;
		}
		.section__content {
			padding: 0 var(--space-md);
		}
	}
</style>
