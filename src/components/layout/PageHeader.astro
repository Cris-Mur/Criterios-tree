---
import { imageEngine } from '@utils/images';
import '@styles/components/page-header.css';

interface Props {
	title: string;
	subtitle?: string;
	bgImage?: ImageMetadata;
}

const { title, subtitle, bgImage } = Astro.props;

let optimizedBg = null;
if (bgImage) {
	optimizedBg = await imageEngine.transform({
		src: bgImage,
		width: 1920,
		quality: 'mid'
	});
}
---

<header class="page-header">
	{optimizedBg && (
		<div 
			class="page-header__bg" 
			style={`background-image: url(${optimizedBg.src})`}
		></div>
	)}
	<div class="page-header__overlay"></div>
	
	<div class="page-header__content container">
		<h1 class="page-header__title text-glow js-reveal-header">{title}</h1>
		{subtitle && <p class="page-header__subtitle js-reveal-header">{subtitle}</p>}
	</div>
</header>

<script>
	import { animations } from '@utils/animations';
	animations.reveal('.js-reveal-header', { y: 20, stagger: 0.2 });
</script>
