---
import { Image } from 'astro:assets';
import Icon from '@components/ui/Icon.astro';
import logoImage from '@assets/branding/logo.png';
import navData from '@data/navigation.json';
import '@styles/components/footer.css';

const currentYear = new Date().getFullYear();
---

<footer class="footer luxury-border">
	<div class="footer__content container">
		<div class="footer__branding">
			<Image 
				src={logoImage} 
				alt="Criterios Logo" 
				width={80} 
				height={80} 
				class="footer__logo"
			/>
			<div class="footer__info">
				<h2 class="text-glow">{navData.credits.brand} Tree</h2>
				<p>{navData.credits.slogan}</p>
			</div>
		</div>

		<nav class="footer__nav">
			<div class="footer__nav-group">
				<h3>Explorar</h3>
				<ul>
					{navData.navigation.map(link => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</div>

			<div class="footer__nav-group">
				<h3>Conecta</h3>
				<div class="footer__socials">
					{navData.socials.map(social => (
						<a href={social.url} target="_blank" aria-label={social.id}>
							<Icon name={social.name} width={24} height={24} />
						</a>
					))}
				</div>
			</div>
		</nav>
	</div>

	<div class="footer__bottom container">
		<p>&copy; {currentYear} {navData.credits.brand} - Todos los derechos reservados.</p>
		<p class="footer__credits">Built with Excellence by <a href={navData.credits.authorUrl} target="_blank">{navData.credits.author}</a></p>
	</div>
</footer>
