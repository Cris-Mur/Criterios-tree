---
import '@styles/components/button.css';

interface Props {
	href?: string;
	variant?: 'solid' | 'outline';
	class?: string;
	[x: string]: any;
}

const { 
	href, 
	variant = 'solid', 
	class: className, 
	...rest 
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag 
	href={href} 
	class:list={[
		'btn', 
		`btn--${variant}`, 
		className
	]} 
	{...rest}
>
	<slot />
</Tag>
