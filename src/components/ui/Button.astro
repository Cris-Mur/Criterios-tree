---
interface Props {
	href?: string;
	variant?: 'solid' | 'outline';
	class?: string;
	[x: string]: any;
}

const { 
	href, 
	variant = 'solid', 
	class: className, 
	...rest 
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag 
	href={href} 
	class:list={[
		'btn', 
		`btn--${variant}`, 
		className
	]} 
	{...rest}
>
	<slot />
</Tag>

<style>
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-sm) var(--space-lg);
		font-family: var(--font-heading);
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 2px;
		cursor: pointer;
		border: none;
		transition: var(--transition-smooth);
		position: relative;
		overflow: hidden;
		text-decoration: none;
	}

	/* Variante Solid */
	.btn--solid {
		background-color: var(--color-gold);
		color: var(--color-void);
		box-shadow: var(--glow-gold);
	}

	.btn--solid:hover {
		background-color: var(--color-stardust);
		transform: translateY(-2px);
		box-shadow: 0 0 25px var(--color-gold-glow);
	}

	/* Variante Outline */
	.btn--outline {
		background-color: transparent;
		color: var(--color-gold);
		border: 1px solid var(--color-gold);
	}

	.btn--outline:hover {
		background-color: var(--color-gold-glow);
		color: var(--color-stardust);
		box-shadow: var(--glow-gold);
		transform: translateY(-2px);
	}

	/* Active State */
	.btn:active {
		transform: translateY(0);
	}
</style>
