---
import { Image } from 'astro:assets';
import Button from './Button.astro';

interface Props {
	title: string;
	description: string;
	price?: number;
	category: string;
	luxury_score: number;
	image: ImageMetadata;
	href: string;
}

const { title, description, price, category, luxury_score, image, href } = Astro.props;

// Lógica para determinar el color del badge según el score
const getScoreColor = (score: number) => {
	if (score >= 9) return 'var(--color-gold)';
	if (score >= 7) return 'var(--color-stardust)';
	return 'rgba(255,255,255,0.6)';
};
---

<article class="card luxury-border">
	<div class="card__image-container">
		<Image 
			src={image} 
			alt={title} 
			width={400} 
			height={300} 
			class="card__image"
		/>
		<div class="card__badge" style={`--score-color: ${getScoreColor(luxury_score)}`}>
			<span class="card__score">{luxury_score.toFixed(1)}</span>
			<span class="card__label">Luxury Score</span>
		</div>
	</div>

	<div class="card__content">
		<header class="card__header">
			<span class="card__category">{category}</span>
			<h3 class="card__title">{title}</h3>
		</header>
		
		<p class="card__description">{description}</p>
		
		<footer class="card__footer">
			{price && <span class="card__price">${price.toFixed(2)}</span>}
			<Button href={href} variant="outline" class="card__btn">
				Ver Detalles
			</Button>
		</footer>
	</div>
</article>

<style>
	.card {
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(10px);
		border-radius: 12px;
		overflow: hidden;
		transition: var(--transition-smooth);
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.card:hover {
		transform: translateY(-5px);
		background: rgba(255, 255, 255, 0.06);
		box-shadow: 0 10px 30px rgba(212, 175, 55, 0.15);
	}

	.card__image-container {
		position: relative;
		aspect-ratio: 4/3;
		overflow: hidden;
	}

	.card__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.card:hover .card__image {
		transform: scale(1.05);
	}

	.card__badge {
		position: absolute;
		top: var(--space-sm);
		right: var(--space-sm);
		background: rgba(0, 0, 0, 0.8);
		border: 1px solid var(--score-color);
		padding: 4px 10px;
		border-radius: 20px;
		display: flex;
		flex-direction: column;
		align-items: center;
		color: var(--score-color);
		box-shadow: 0 0 10px rgba(0,0,0,0.5);
	}

	.card__score {
		font-family: var(--font-heading);
		font-size: 1.1rem;
		font-weight: bold;
		line-height: 1;
	}

	.card__label {
		font-size: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.card__content {
		padding: var(--space-md);
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.card__category {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: var(--color-gold);
		opacity: 0.8;
	}

	.card__title {
		font-size: 1.25rem;
		margin-top: 4px;
	}

	.card__description {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card__footer {
		margin-top: auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: var(--space-sm);
		border-top: 1px solid rgba(212, 175, 55, 0.1);
	}

	.card__price {
		font-family: var(--font-heading);
		color: var(--color-gold);
		font-weight: bold;
	}

	.card__btn {
		font-size: 0.7rem;
		padding: 8px 16px;
	}
</style>
