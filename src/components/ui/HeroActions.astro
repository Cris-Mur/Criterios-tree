---
import Button from './Button.astro';
import '@styles/components/hero-actions.css';

interface Props {
	primaryHref?: string;
	primaryLabel?: string;
	secondaryHref?: string;
	secondaryLabel?: string;
	class?: string;
}

const {
	primaryHref,
	primaryLabel,
	secondaryHref,
	secondaryLabel,
	class: className
} = Astro.props;
---

<div class:list={['hero-actions', className]}>
	{primaryLabel && (
		<Button href={primaryHref} variant="solid">
			{primaryLabel}
		</Button>
	)}
	
	{secondaryLabel && (
		<Button href={secondaryHref} variant="outline">
			{secondaryLabel}
		</Button>
	)}
</div>
