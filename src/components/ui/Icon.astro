---
import '@styles/components/icon.css';

/**
 * Componente Icon: Renderiza SVGs locales de src/assets/icons/
 * Uso: <Icon name="facebook_logo" width={24} height={24} />
 */
interface Props {
	name: string;
	width?: number | string;
	height?: number | string;
	class?: string;
}

const { name, width = 24, height = 24, class: className } = Astro.props;

// Cargamos dinámicamente el contenido del SVG
let svgContent = '';
try {
	const icons = import.meta.glob('/src/assets/icons/*.svg', { 
		query: '?raw', 
		import: 'default',
		eager: true 
	});
	const path = `/src/assets/icons/${name}.svg`;
	svgContent = icons[path] || '';
	
	if (!svgContent) {
		console.warn(`[Icon] No se encontró el icono: ${name}`);
	}
} catch (e) {
	console.error(`[Icon] Error cargando el icono: ${name}`, e);
}
---

{svgContent ? (
	<div 
		class:list={['icon-wrapper', className]} 
		style={`width: ${width}px; height: ${height}px;`}
		data-icon={name}
		role="img"
		aria-hidden="true"
		set:html={svgContent}
	/>
) : null}
