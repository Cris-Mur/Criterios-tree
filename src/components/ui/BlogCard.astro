---
import { Image } from 'astro:assets';
import '@styles/components/blog-card.css';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	author: string;
	image: ImageMetadata;
	href: string;
	tags?: string[];
}

const { title, description, pubDate, author, image, href, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<article class="blog-card">
	<a href={href} class="blog-card__link">
		<div class="blog-card__image-container luxury-border">
			<Image 
				src={image} 
				alt={title} 
				width={600} 
				height={400} 
				class="blog-card__image"
			/>
		</div>
		
		<div class="blog-card__content">
			<div class="blog-card__meta">
				<time datetime={pubDate.toISOString()}>{formattedDate}</time>
				<span class="blog-card__separator">|</span>
				<span>{author}</span>
			</div>
			
			<h3 class="blog-card__title text-glow">{title}</h3>
			
			<p class="blog-card__description">{description}</p>
			
			{tags.length > 0 && (
				<div class="blog-card__tags">
					{tags.map(tag => (
						<span class="blog-card__tag">#{tag}</span>
					))}
				</div>
			)}
		</div>
	</a>
</article>
