---
import { Image } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	author: string;
	image: ImageMetadata;
	href: string;
	tags?: string[];
}

const { title, description, pubDate, author, image, href, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<article class="blog-card">
	<a href={href} class="blog-card__link">
		<div class="blog-card__image-container luxury-border">
			<Image 
				src={image} 
				alt={title} 
				width={600} 
				height={400} 
				class="blog-card__image"
			/>
		</div>
		
		<div class="blog-card__content">
			<div class="blog-card__meta">
				<time datetime={pubDate.toISOString()}>{formattedDate}</time>
				<span class="blog-card__separator">|</span>
				<span>{author}</span>
			</div>
			
			<h3 class="blog-card__title text-glow">{title}</h3>
			
			<p class="blog-card__description">{description}</p>
			
			{tags.length > 0 && (
				<div class="blog-card__tags">
					{tags.map(tag => (
						<span class="blog-card__tag">#{tag}</span>
					))}
				</div>
			)}
		</div>
	</a>
</article>

<style>
	.blog-card {
		transition: var(--transition-smooth);
	}

	.blog-card__link {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		text-decoration: none;
	}

	.blog-card__image-container {
		border-radius: 8px;
		overflow: hidden;
		aspect-ratio: 16/9;
	}

	.blog-card__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.blog-card:hover .blog-card__image {
		transform: scale(1.05);
	}

	.blog-card__content {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.blog-card__meta {
		font-family: var(--font-heading);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		color: var(--color-gold);
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.blog-card__title {
		font-size: 1.5rem;
		line-height: 1.3;
		transition: var(--transition-smooth);
	}

	.blog-card:hover .blog-card__title {
		color: var(--color-gold);
	}

	.blog-card__description {
		font-size: 0.95rem;
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__tags {
		display: flex;
		gap: 12px;
		margin-top: var(--space-xs);
	}

	.blog-card__tag {
		font-size: 0.75rem;
		color: var(--color-gold);
		opacity: 0.6;
		font-family: var(--font-heading);
	}
</style>
