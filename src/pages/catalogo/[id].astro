---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionContainer from '@components/layout/SectionContainer.astro';
import Button from '@components/ui/Button.astro';
import { Image } from 'astro:assets';
import '@styles/pages/product-detail.css';

export async function getStaticPaths() {
	const products = await getCollection('products');
	return products.map(product => ({
		params: { id: product.id },
		props: { product },
	}));
}

const { product } = Astro.props;
const { Content } = await render(product);

const title = `${product.data.title} | Criterios Tree`;
const description = product.data.description;

// Generar mensaje dinámico para WhatsApp
const whatsappMessage = encodeURIComponent(`Hola Criterios! Me interesa el producto: ${product.data.title}. Quisiera más información.`);
const whatsappLink = `https://wa.me/573208722922?text=${whatsappMessage}`;
---

<BaseLayout title={title} description={description}>
	<main>
		<SectionContainer variant="nebula" class="product-detail">
			<div class="product-detail__grid">
				<div class="product-detail__image-wrapper">
					<Image 
						src={product.data.image} 
						alt={product.data.title} 
						width={600} 
						height={600} 
						class="product-detail__image luxury-border"
					/>
				</div>
				
				<div class="product-detail__info">
					<nav class="breadcrumb">
						<a href="/catalogo">Catálogo</a> / <span>{product.data.category}</span>
					</nav>
					
					<h1 class="text-glow">{product.data.title}</h1>
					
					<div class="product-detail__meta">
						<div class="score-badge">
							<span>Luxury Score: <strong>{product.data.luxury_score.toFixed(1)}</strong></span>
						</div>
						{product.data.price && <span class="product-detail__price">${product.data.price.toFixed(2)}</span>}
					</div>

					<p class="product-detail__description">
						{product.data.description}
					</p>

					<div class="product-detail__body">
						<Content />
					</div>

					<div class="product-detail__actions">
						<Button href={whatsappLink} variant="solid" target="_blank">
							Solicitar vía WhatsApp
						</Button>
						<Button href="/catalogo" variant="outline">
							Volver al Catálogo
						</Button>
					</div>
				</div>
			</div>
		</SectionContainer>
	</main>
</BaseLayout>
