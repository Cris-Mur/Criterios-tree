---
import BaseLayout from './BaseLayout.astro';
import SectionContainer from '@components/layout/SectionContainer.astro';
import { Image } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	author: string;
	image: ImageMetadata;
	tags?: string[];
}

const { title, description, pubDate, author, image, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
	<main>
		<article class="post">
			<header class="post__header">
				<SectionContainer variant="nebula" class="post__hero">
					<div class="post__meta">
						<time datetime={pubDate.toISOString()}>{formattedDate}</time>
						<span>•</span>
						<span>{author}</span>
					</div>
					<h1 class="text-glow">{title}</h1>
					<div class="post__tags">
						{tags.map(tag => <span class="post__tag">#{tag}</span>)}
					</div>
				</SectionContainer>
			</header>

			<SectionContainer variant="stardust" class="post__content-wrapper">
				<div class="post__image-container luxury-border">
					<Image 
						src={image} 
						alt={title} 
						width={1000} 
						height={500} 
						class="post__image"
					/>
				</div>

				<div class="post__content">
					<slot />
				</div>
				
				<footer class="post__footer">
					<a href="/blog" class="post__back">← Volver al Blog</a>
				</footer>
			</SectionContainer>
		</article>
	</main>
</BaseLayout>

<style is:global>
	/* Estilos para el contenido renderizado de Markdown */
	.post__content {
		max-width: 720px;
		margin: 0 auto;
		font-size: 1.15rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.9);
	}

	.post__content p { margin-bottom: 1.5rem; }
	.post__content h2 { margin: 2rem 0 1rem; font-size: 1.75rem; color: var(--color-gold); }
	.post__content h3 { margin: 1.5rem 0 0.75rem; font-size: 1.4rem; }
	.post__content ul, .post__content ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
	.post__content li { margin-bottom: 0.5rem; }
	.post__content blockquote {
		border-left: 4px solid var(--color-gold);
		padding: 1rem 1.5rem;
		background: rgba(212, 175, 55, 0.05);
		font-style: italic;
		margin-bottom: 1.5rem;
	}
</style>

<style>
	.post__hero {
		text-align: center;
		padding: var(--space-xl) 0;
	}

	.post__meta {
		font-family: var(--font-heading);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: var(--color-gold);
		margin-bottom: var(--space-sm);
	}

	.post__hero h1 {
		font-size: clamp(2.5rem, 8vw, 4rem);
		margin-bottom: var(--space-md);
		max-width: 900px;
		margin-left: auto;
		margin-right: auto;
	}

	.post__tags {
		display: flex;
		justify-content: center;
		gap: var(--space-sm);
	}

	.post__tag {
		font-size: 0.9rem;
		opacity: 0.7;
	}

	.post__image-container {
		margin: calc(var(--space-xl) * -1) auto var(--space-xl);
		max-width: 900px;
		border-radius: 12px;
		overflow: hidden;
		position: relative;
		z-index: 20;
	}

	.post__image {
		width: 100%;
		height: auto;
		display: block;
	}

	.post__footer {
		max-width: 720px;
		margin: var(--space-xl) auto 0;
		padding-top: var(--space-md);
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.post__back {
		font-family: var(--font-heading);
		color: var(--color-gold);
		text-transform: uppercase;
		font-size: 0.9rem;
		letter-spacing: 1px;
	}

	.post__back:hover {
		color: var(--color-stardust);
	}
</style>
