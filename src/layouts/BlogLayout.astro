---
import BaseLayout from './BaseLayout.astro';
import SectionContainer from '@components/layout/SectionContainer.astro';
import { Image } from 'astro:assets';
import '@styles/layouts/blog-layout.css';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	author: string;
	image: ImageMetadata;
	tags?: string[];
}

const { title, description, pubDate, author, image, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
	<main>
		<article class="post">
			<header class="post__header">
				<SectionContainer variant="nebula" class="post__hero">
					<div class="post__meta">
						<time datetime={pubDate.toISOString()}>{formattedDate}</time>
						<span>•</span>
						<span>{author}</span>
					</div>
					<h1 class="text-glow">{title}</h1>
					<div class="post__tags">
						{tags.map(tag => <span class="post__tag">#{tag}</span>)}
					</div>
				</SectionContainer>
			</header>

			<SectionContainer variant="stardust" class="post__content-wrapper">
				<div class="post__image-container luxury-border">
					<Image 
						src={image} 
						alt={title} 
						width={1000} 
						height={500} 
						class="post__image"
					/>
				</div>

				<div class="post__content">
					<slot />
				</div>
				
				<footer class="post__footer">
					<a href="/blog/" class="post__back">← Volver al Blog</a>
				</footer>
			</SectionContainer>
		</article>
	</main>
</BaseLayout>
